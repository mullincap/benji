# =============================================================================
# .env.example — Benji3m environment variables
# =============================================================================
# Copy this file to .env and fill in all values before running setup.sh.
# NEVER commit .env to git — it is in .gitignore.
#
#   cp .env.example .env && nano .env
#
# After filling in, run:
#   bash setup.sh
# =============================================================================


# ─── Domain + SSL ─────────────────────────────────────────────────────────────
# Leave DOMAIN empty to run in HTTP-only mode (useful for testing a new instance
# before DNS is pointed at it). Add SSL later with: bash setup.sh --ssl-only
DOMAIN=
SSL_EMAIL=


# ─── Data pipeline ────────────────────────────────────────────────────────────

# Amberdata API key (required by metl.py)
AMBER_API_KEY=

# CoinGecko Demo API key (required by coingecko_marketcap.py)
# Get one free at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=


# ─── TimescaleDB ──────────────────────────────────────────────────────────────
# These are used by setup.sh to create the DB and by .env.production at runtime.

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=marketdata
DB_USER=quant
DB_PASSWORD=


# ─── App (backend / frontend) ─────────────────────────────────────────────────
# Add your existing app-specific variables below.
# These are merged into .env.production by setup.sh.

# Example:
# SECRET_KEY=
# JWT_SECRET=
