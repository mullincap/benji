# Data paths (mounted as /data on the server)
BASE_DATA_DIR=/data
PARQUET_PATH=/data/oi_raw/master_data_table.parquet
MARKETCAP_DIR=/data/marketcap

# Runtime paths (inside Docker container)
JOBS_DIR=/app/backend/jobs
PIPELINE_DIR=/app/pipeline
REDIS_URL=redis://redis:6379/0
NODE_BIN=node
PIPELINE_PYTHON=python

# CORS — allow all origins (nginx handles external access)
CORS_ORIGINS=*
